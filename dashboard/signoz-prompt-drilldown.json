  "variables": {
    "var-prompt-id": {
      "id": "var-prompt-id",
      "name": "prompt_id",
      "description": "Pilih prompt (prompt.id) untuk di-drill-down. Cocokkan dengan tabel ① di bawah.",
      "type": "QUERY",
      "queryValue": "SELECT attributes_string['prompt.id'] AS prompt_id FROM signoz_logs.distributed_logs_v2 WHERE attributes_string['event.name'] = 'user_prompt' AND attributes_string['prompt.id'] != '' GROUP BY prompt_id ORDER BY max(timestamp) DESC LIMIT 50",
      "customValue": "",
      "textboxValue": "",
      "multiSelect": false,
      "showALLOption": false,
      "sort": "DISABLED",
      "order": 0,
      "modificationUUID": "var-prompt-id",
      "selectedValue": ""
    }
  },
