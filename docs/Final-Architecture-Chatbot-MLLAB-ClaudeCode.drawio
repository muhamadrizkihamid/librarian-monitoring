                <mxCell id="al-ch" value="ClickHouse / SigNoz&#xa;(store permanen / source of truth)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="al-1">
