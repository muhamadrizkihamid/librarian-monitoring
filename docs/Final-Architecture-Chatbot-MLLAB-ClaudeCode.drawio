                <mxCell id="al-signoz" value="SigNoz UI :8080&#xa;(4 dashboard analitis)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="al-1">
                    <mxGeometry x="700" y="240" width="200" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="al-browser" value="Browser&#xa;(user &#8594; sesi &#8594; prompt)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="al-1">
                    <mxGeometry x="700" y="380" width="200" height="60" as="geometry"/>
                </mxCell>
                <mxCell id="al-note" value="TIDAK dibangun di MVP: L1 Gateway (Chatbot), L3 Egress/DLP/CASB, L4 Compliance API, Ingest Queue durable, Normalizer CEF, Reconciler, SIEM, Audit WORM/hash-chain.&#xa;&#8658; Kelengkapan BELUM terbukti (lihat LLD &#167;7 &amp; &#167;11): L2 bisa dimatikan/di-bypass; tanpa L3 + rekonsiliasi billing, klaim 'menangkap semua aktivitas' tidak terbukti." style="rounded=0;whiteSpace=wrap;html=1;align=left;verticalAlign=top;fillColor=#f8cecc;strokeColor=#b85450;fontStyle=2;" vertex="1" parent="al-1">
                    <mxGeometry x="40" y="600" width="540" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="al-e1" value="OTLP :4317/:4318" style="endArrow=block;html=1;" edge="1" parent="al-1" source="al-cli" target="al-col">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="al-e2" value="fan-out (file)" style="endArrow=block;html=1;" edge="1" parent="al-1" source="al-col" target="al-jsonl">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="al-e3" value="fan-out (otlp)" style="endArrow=block;html=1;" edge="1" parent="al-1" source="al-col" target="al-ch">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="al-e4" value="fan-out (HEC)" style="endArrow=block;html=1;" edge="1" parent="al-1" source="al-col" target="al-live">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="al-e5" value="poll 30 hari" style="endArrow=block;html=1;dashed=1;" edge="1" parent="al-1" source="al-ch" target="al-live">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="al-e6" value="cache (TTL 30h)" style="endArrow=block;startArrow=block;html=1;" edge="1" parent="al-1" source="al-live" target="al-redis">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="al-e7" value="WebSocket" style="endArrow=block;html=1;" edge="1" parent="al-1" source="al-live" target="al-browser">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="al-e8" value="query" style="endArrow=block;html=1;dashed=1;" edge="1" parent="al-1" source="al-ch" target="al-signoz">
                    <mxGeometry relative="1" as="geometry"/>
                </mxCell>
                <mxCell id="al-gloss-title" value="FOOTNOTE &#8212; Glosarium istilah &amp; singkatan (semua tab)" style="text;html=1;align=left;verticalAlign=middle;fontSize=13;fontStyle=1;" vertex="1" parent="al-1">
                    <mxGeometry x="40" y="760" width="640" height="26" as="geometry"/>
                </mxCell>
                <mxCell id="al-gloss-l" value="ARSITEKTUR &amp; DOKUMEN&#xa;HLD = High-Level Design (desain ringkas/tingkat tinggi).&#xa;LLD = Low-Level Design (desain rinci/detail).&#xa;source of truth = sumber kebenaran tunggal (data acuan utama).&#xa;&#xa;LLM &amp; VENDOR&#xa;LLM = Large Language Model (model bahasa besar, mis. GPT/Claude).&#xa;GPT = model OpenAI yang dipakai Chatbot.&#xa;Claude / Anthropic = LLM Anthropic yang dipakai Claude Code.&#xa;SaaS = Software as a Service (layanan pihak ketiga via internet).&#xa;API = Application Programming Interface (antarmuka antar program).&#xa;&#xa;CLAUDE CODE (KLIEN)&#xa;CLI = Command Line Interface (antarmuka baris perintah).&#xa;IDE = Integrated Development Environment (editor kode, mis. VS Code).&#xa;MDM = Mobile Device Management (kelola perangkat terpusat; push managed-settings).&#xa;managed-settings = konfigurasi terkunci, tak bisa diubah developer.&#xa;hooks = skrip yang jalan saat event tool (PreToolUse/PostToolUse).&#xa;spend limit = batas biaya per user.&#xa;&#xa;DATA &amp; MODEL INTERNAL&#xa;MCP = Model Context Protocol (gerbang tool ke model/data bank; batas Aturan Emas).&#xa;ML LAB = zona data sensitif internal (model bank + data nasabah).&#xa;MLOps = Machine Learning Operations (kelola siklus hidup model).&#xa;scoring/fraud = model bank (skor risiko kredit / deteksi penipuan).&#xa;E-DOC = dokumen elektronik internal (non-sensitif).&#xa;SCM = Source Code Management (repositori kode, mis. Git).&#xa;Aturan Emas = data nasabah dan output model bank TIDAK keluar ke LLM eksternal.&#xa;&#xa;KEAMANAN &amp; JARINGAN&#xa;PII = Personally Identifiable Information (data pribadi: NIK, kartu, email).&#xa;DLP = Data Loss Prevention (cegah kebocoran data sensitif).&#xa;CASB = Cloud Access Security Broker (kontrol akses layanan cloud/web).&#xa;SIEM = Security Information and Event Management (korelasi dan deteksi keamanan).&#xa;Egress proxy = gerbang keluar; semua trafik vendor wajib lewat sini.&#xa;guardrail = pagar pengaman (moderasi, cek prompt-injection).&#xa;LDAP = Lightweight Directory Access Protocol (direktori user korporat).&#xa;SAML = Security Assertion Markup Language (standar Single Sign-On).&#xa;mTLS = mutual TLS (enkripsi dua-arah dengan verifikasi sertifikat).&#xa;TLS = Transport Layer Security (enkripsi koneksi / HTTPS)." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=11;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="al-1">
                    <mxGeometry x="40" y="794" width="460" height="740" as="geometry"/>
                </mxCell>
                <mxCell id="al-gloss-r" value="TELEMETRI &amp; PIPELINE&#xa;OTel = OpenTelemetry (standar telemetri: log/metrik/trace).&#xa;OTLP = OpenTelemetry Protocol (protokol kirim telemetri; port 4317/4318).&#xa;HEC = HTTP Event Collector (endpoint ala Splunk; memicu trapping-live).&#xa;CEF = Common Event Format (skema event terpadu lintas sumber).&#xa;Ingest Queue = antrian penampung (durable, tahan lonjakan).&#xa;Normalizer = penyeragam event ke satu skema.&#xa;Enricher = pelengkap event (user_id, cost, klasifikasi DLP).&#xa;Router = penyebar event ke banyak tujuan (fan-out).&#xa;Reconciler = rekonsiliasi antar sumber untuk deteksi shadow-usage.&#xa;at-least-once = jaminan event terkirim minimal sekali (boleh dobel, didedup).&#xa;dedup = penghapusan duplikat (via event_id).&#xa;fan-out = satu input disebar ke banyak output.&#xa;&#xa;PENYIMPANAN &amp; DASHBOARD (MVP)&#xa;ClickHouse = database analitik (store permanen / source of truth).&#xa;SigNoz = platform observability (UI dashboard di :8080).&#xa;Redis = penyimpan in-memory cepat (hot store dashboard, TTL 30 hari).&#xa;trapping-live = dashboard live (:8091, WebSocket).&#xa;WebSocket = koneksi dua-arah real-time browser-server.&#xa;TTL = Time To Live (umur data sebelum kedaluwarsa).&#xa;WORM = Write Once Read Many (sekali tulis, tak bisa diubah; untuk audit).&#xa;BI = Business Intelligence (analitik biaya/token, chargeback).&#xa;chargeback = pembebanan biaya ke tim/user pemakai.&#xa;&#xa;LAPISAN &amp; KELENGKAPAN&#xa;L1-L4 = empat lapisan penangkapan (Gateway, OTel/Hooks, Egress, Compliance).&#xa;L7 = Layer 7 OSI (lapisan aplikasi; log per-request, bukan koneksi TCP).&#xa;in-band = di jalur lalu lintas (bisa blokir real-time).&#xa;out-of-band = di luar jalur (reaktif, tidak memblokir).&#xa;backstop = jaring pengaman terakhir (L3 egress).&#xa;shadow-usage = pemakaian LLM tak terpantau (lolos dari telemetri).&#xa;Compliance API = API vendor (Enterprise) untuk tarik/hapus konten.&#xa;user_id = email korporat; kunci join lintas platform.&#xa;HA = High Availability (ketersediaan tinggi, minimal 2 instance).&#xa;UI = User Interface (antarmuka pengguna)." style="rounded=1;whiteSpace=wrap;html=1;align=left;verticalAlign=top;spacing=8;fontSize=11;fillColor=#f5f5f5;strokeColor=#999999;" vertex="1" parent="al-1">
                    <mxGeometry x="520" y="794" width="460" height="600" as="geometry"/>
                </mxCell>
            </root>
        </mxGraphModel>
    </diagram>
</mxfile>