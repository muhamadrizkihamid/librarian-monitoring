                <mxCell id="ts-e" value="Enricher&#xa;user_id · cost&#xa;DLP class" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#9673A6;fontSize=11;" parent="1" vertex="1">
