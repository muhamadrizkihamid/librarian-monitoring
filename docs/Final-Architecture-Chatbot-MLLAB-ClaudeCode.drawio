    <diagram id="actual-lld-001" name="Actual LLD">
        <mxGraphModel dx="1200" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1000" pageHeight="1560" math="0" shadow="0">
            <root>
                <mxCell id="al-0"/>
                <mxCell id="al-1" parent="al-0"/>
                <mxCell id="al-title" value="Actual LLD &#8212; As-Built MVP (Juni 2026): hanya L2 (Claude Code)" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;" vertex="1" parent="al-1">
                    <mxGeometry x="40" y="20" width="640" height="30" as="geometry"/>
                </mxCell>
                <mxCell id="al-cli" value="Claude Code CLI&#xa;(managed-settings.json + hooks/trap.mjs)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;" vertex="1" parent="al-1">
                    <mxGeometry x="40" y="80" width="220" height="70" as="geometry"/>
