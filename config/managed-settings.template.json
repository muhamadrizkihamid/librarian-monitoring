{
  "_comment": "Template managed-settings Claude Code (IMMUTABLE, di-push via MDM). Placeholder __TRAP_DIR__ & __OTLP_ENDPOINT__ diisi oleh scripts/build-managed-settings.mjs. Deploy file trapping (hooks/ + config/) ke __TRAP_DIR__ di tiap mesin, lalu taruh hasil generate di path managed-settings OS.",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "__OTLP_ENDPOINT__",
    "OTEL_LOG_USER_PROMPTS": "1",
    "OTEL_LOG_TOOL_DETAILS": "1",
    "OTEL_LOG_RAW_API_BODIES": "1",
    "OTEL_METRIC_EXPORT_INTERVAL": "10000",
    "OTEL_LOGS_EXPORT_INTERVAL": "2000",
    "TRAP_OTLP_ENDPOINT": "__OTLP_ENDPOINT__"
  },
  "hooks": {
    "UserPromptSubmit": [{ "hooks": [{ "type": "command", "command": "node \"__TRAP_DIR__/hooks/trap.mjs\"" }] }],
    "PreToolUse":        [{ "hooks": [{ "type": "command", "command": "node \"__TRAP_DIR__/hooks/trap.mjs\"" }] }],
    "PostToolUse":       [{ "hooks": [{ "type": "command", "command": "node \"__TRAP_DIR__/hooks/trap.mjs\"" }] }],
    "PostToolUseFailure":[{ "hooks": [{ "type": "command", "command": "node \"__TRAP_DIR__/hooks/trap.mjs\"" }] }],
    "Stop":              [{ "hooks": [{ "type": "command", "command": "node \"__TRAP_DIR__/hooks/trap.mjs\"" }] }],
    "SessionStart":      [{ "hooks": [{ "type": "command", "command": "node \"__TRAP_DIR__/hooks/trap.mjs\"" }] }],
    "SessionEnd":        [{ "hooks": [{ "type": "command", "command": "node \"__TRAP_DIR__/hooks/trap.mjs\"" }] }]
  },
  "disableBypassPermissionsMode": true,
  "forceRemoteSettingsRefresh": false
}
