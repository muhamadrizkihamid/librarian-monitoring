{
  "version": "2026-06-14.2",
  "fail_mode": "open",
  "_doc": "rules = enforcement PreToolUse (aksi). prompt_rules = enforcement UserPromptSubmit (teks prompt). action: deny (blokir) | flag (izinkan + tandai). Rule pertama yang cocok menang; taruh deny dulu. field (rules): command|path|any. match: contains[] (substring) atau regex (case-insensitive). tool: pipe-separated; 'mcp' utk semua mcp__*, '*' utk semua.",
  "rules": [
    {
      "id": "bash-rm-recursive-force",
      "tool": "Bash",
      "field": "command",
      "regex": "\\brm\\b.*(-[a-zA-Z]*r[a-zA-Z]*f|-[a-zA-Z]*f[a-zA-Z]*r|--recursive)",
      "action": "deny",
      "reason": "Perintah 'rm' rekursif/paksa diblokir kebijakan korporat."
    },
    {
      "id": "bash-fork-bomb",
      "tool": "Bash",
      "field": "command",
      "regex": ":\\s*\\(\\s*\\)\\s*\\{",
      "action": "deny",
      "reason": "Pola fork bomb diblokir."
    },
    {
      "id": "bash-disk-power",
      "tool": "Bash",
      "field": "command",
      "regex": "\\b(mkfs\\S*|dd\\s+if=|shutdown|reboot)\\b|format\\s+[a-zA-Z]:",
      "action": "deny",
      "reason": "Operasi disk/power berbahaya diblokir."
    },
    {
      "id": "antitamper-claude-settings",
      "tool": "Edit|Write|MultiEdit",
      "field": "path",
      "contains": ["managed-settings.json", ".claude/settings.json", ".claude\\settings.json"],
      "action": "deny",
      "reason": "Mengubah settings/kebijakan Claude Code diblokir (anti-tamper trapping)."
    },
    {
      "id": "secrets-access",
      "tool": "Read|Bash",
      "field": "any",
      "regex": "(\\.credentials\\.json|id_rsa|(^|[/\\\\])\\.env\\b|\\.pem\\b|secrets?\\.ya?ml)",
      "action": "flag",
      "reason": "Akses kredensial/secret ditandai untuk audit."
    }
  ],
  "prompt_rules": [
    {
      "id": "prompt-destroy-db",
      "match": "regex",
      "regex": "\\b(drop|truncate)\\s+(database|table)\\b|\\bdelete\\s+from\\b[\\s\\S]*\\bwhere\\b\\s+1\\s*=\\s*1",
      "action": "deny",
      "reason": "Prompt memerintahkan penghapusan/penghancuran basis data."
    },
    {
      "id": "prompt-disable-trapping",
      "regex": "(matikan|non-?aktifkan|disable|bypass|lewati|akali).{0,30}(trapping|monitoring|audit|hook|policy|managed.?settings|enforcement)",
      "action": "deny",
      "reason": "Prompt meminta menonaktifkan/melewati trapping atau audit."
    },
    {
      "id": "prompt-exfil-customer",
      "regex": "(kirim|unggah|upload|ekspor|export|bocorkan|leak|salin\\s+keluar).{0,40}(data\\s+nasabah|nomor\\s+rekening|nomor\\s+kartu|customer\\s+data|cardholder|mutasi\\s+rekening)",
      "action": "deny",
      "reason": "Prompt mengindikasikan eksfiltrasi data nasabah ke luar."
    },
    {
      "id": "prompt-mentions-credential",
      "regex": "(password|kata\\s+sandi|kredensial|credential|api[\\s_-]?key|secret\\s+key|private\\s+key|token\\s+akses)",
      "action": "flag",
      "reason": "Prompt menyebut kredensial — ditandai untuk audit."
    },
    {
      "id": "prompt-mentions-customer-pii",
      "regex": "(data\\s+nasabah|nomor\\s+rekening|\\bnik\\b|nomor\\s+ktp|nomor\\s+kartu\\s+kredit|cvv|pin\\s+atm)",
      "action": "flag",
      "reason": "Prompt menyebut data sensitif nasabah — ditandai untuk audit."
    }
  ]
}
